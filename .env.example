# =============================================
# Producción H61 — Dashboard
# Variables de entorno necesarias
# =============================================

# Turso (base de datos SQLite serverless)
# 1. Instalar Turso CLI:  curl -sSfL https://get.tur.so/install.sh | bash
# 2. Loguearse:  turso auth login
# 3. Crear DB:  turso db create produccion-h61
# 4. Obtener URL y token:
#    turso db show produccion-h61 --url
#    turso db tokens create produccion-h61
TURSO_DATABASE_URL=libsql://produccion-h61-tu-usuario.turso.io
TURSO_AUTH_TOKEN=tu-auth-token-aqui