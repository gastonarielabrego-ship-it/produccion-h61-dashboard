# =============================================
# Producción H61 — Dashboard
# Variables de entorno necesarias
# =============================================

# Google Sheets (base de datos)
# 1. Crear un Google Sheet con la hoja "Datos" y el mismo formato que h61 ver.xlsx
# 2. Ir a https://console.cloud.google.com/ → Crear proyecto
# 3. Habilitar "Google Sheets API"
# 4. Crear una "Cuenta de servicio" → Descargar clave JSON
# 5. Compartir el Google Sheet con el email de la cuenta de servicio (Editor)
GOOGLE_SHEETS_SPREADSHEET_ID=tu_spreadsheet_id_aqui
GOOGLE_SERVICE_ACCOUNT_EMAIL=tu-service-account@tu-proyecto.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nTU_CLAVE_PRIVADA_AQUI\n-----END PRIVATE KEY-----\n"